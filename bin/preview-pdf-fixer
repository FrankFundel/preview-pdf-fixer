#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  preview-pdf-fixer [options] input.pdf [input2.pdf ...]
  preview-pdf-fixer [options] figure.svg

Fix PDFs/SVGs that render incorrectly in macOS Preview/Safari. PDF inputs are
rewritten with Ghostscript; the default mode flattens transparency to PDF 1.3,
which is the safest option for Figma exports embedded through LaTeX/pdfTeX.
SVG inputs in flatten mode are rasterized into PDF pages to avoid reintroducing
soft masks.

Options:
  -o, --output FILE     Output file. Only valid with one input.
  --out-dir DIR         Write outputs to DIR instead of beside each input.
  --suffix TEXT         Output suffix before .pdf (default: _preview)
  --mode flatten        Preview-safe PDF 1.3 flattening (default)
  --mode rewrite        Smaller PDF 1.4 rewrite; less aggressive
  --no-preserve-links   Do not restore original PDF link annotations
  --svg-scale N         Raster scale for SVG flatten mode (default: 1)
  -h, --help            Show this help

Examples:
  preview-pdf-fixer paper.pdf
  preview-pdf-fixer -o paper_preview.pdf paper.pdf
  preview-pdf-fixer --out-dir fixed figures/*.pdf
  preview-pdf-fixer --svg-scale 2 --out-dir fixed figures/*.svg
  preview-pdf-fixer --mode rewrite -o paper_rewrite.pdf paper.pdf
USAGE
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

lower_ext() {
  local name=${1##*/}
  local ext=${name##*.}
  printf '%s' "$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"
}

default_output_for() {
  local input=$1
  local base dir stem

  base=$(basename "$input")
  stem=${base%.*}
  if [[ -n "$out_dir" ]]; then
    mkdir -p "$out_dir"
    printf '%s/%s%s.pdf' "$out_dir" "$stem" "$suffix"
  else
    dir=$(dirname "$input")
    printf '%s/%s%s.pdf' "$dir" "$stem" "$suffix"
  fi
}

validate_svg_scale() {
  python3 - "$svg_scale" <<'PY' >/dev/null
import sys

try:
    scale = float(sys.argv[1])
except ValueError:
    raise SystemExit(1)
if scale <= 0:
    raise SystemExit(1)
PY
}

svg_to_vector_pdf() {
  local input=$1
  local output=$2

  if command -v rsvg-convert >/dev/null 2>&1; then
    rsvg-convert -f pdf -o "$output" "$input"
  elif command -v inkscape >/dev/null 2>&1; then
    inkscape "$input" --export-type=pdf --export-filename="$output"
  else
    die "SVG rewrite mode needs rsvg-convert or inkscape"
  fi
}

svg_to_raster_pdf() {
  local input=$1
  local output=$2
  local png=$3
  local dpi

  need_cmd rsvg-convert
  need_cmd python3
  validate_svg_scale || die "--svg-scale must be a positive number"

  dpi=$(python3 - "$svg_scale" <<'PY'
import sys
print(96 * float(sys.argv[1]))
PY
)

  rsvg-convert -f png -z "$svg_scale" -b white -o "$png" "$input"
  python3 - "$png" "$output" "$dpi" <<'PY'
from PIL import Image
import sys

png, output, dpi = sys.argv[1], sys.argv[2], float(sys.argv[3])
img = Image.open(png)
if img.mode in ("RGBA", "LA") or (img.mode == "P" and "transparency" in img.info):
    rgba = img.convert("RGBA")
    bg = Image.new("RGB", rgba.size, "white")
    bg.paste(rgba, mask=rgba.getchannel("A"))
    img = bg
else:
    img = img.convert("RGB")
img.save(output, "PDF", resolution=dpi, quality=95)
PY
}

fix_pdf() {
  local input=$1
  local output=$2
  local compat
  local visual_output
  local tmp_output

  need_cmd gs

  case "$mode" in
    flatten) compat=1.3 ;;
    rewrite) compat=1.4 ;;
    *) die "unknown mode: $mode" ;;
  esac

  visual_output="$tmp_dir/$(basename "$output").visual.pdf"
  tmp_output="$tmp_dir/$(basename "$output").tmp.pdf"

  gs \
    -dSAFER \
    -dBATCH \
    -dNOPAUSE \
    -q \
    -sDEVICE=pdfwrite \
    -dCompatibilityLevel="$compat" \
    -dPrinted=false \
    -dDetectDuplicateImages=true \
    -dCompressFonts=true \
    -dSubsetFonts=true \
    -dDownsampleColorImages=false \
    -dDownsampleGrayImages=false \
    -dDownsampleMonoImages=false \
    -sColorConversionStrategy=RGB \
    -dProcessColorModel=/DeviceRGB \
    -sOutputFile="$visual_output" \
    "$input"

  if [[ "$preserve_links" == true ]]; then
    restore_pdf_links "$input" "$visual_output" "$tmp_output"
  else
    mv "$visual_output" "$tmp_output"
  fi

  mv "$tmp_output" "$output"
}

restore_pdf_links() {
  local original=$1
  local visual=$2
  local output=$3

  need_cmd python3

  python3 - "$original" "$visual" "$output" <<'PY'
import copy
import sys

try:
    from PyPDF2 import PdfReader, PdfWriter
    from PyPDF2.generic import (
        ArrayObject,
        DictionaryObject,
        FloatObject,
        NameObject,
        NullObject,
        NumberObject,
        TextStringObject,
        create_string_object,
    )
except ImportError:
    raise SystemExit(
        "PyPDF2 is required to preserve PDF links. Install it with "
        "`python3 -m pip install PyPDF2`, or rerun with --no-preserve-links."
    )

original_path, visual_path, output_path = sys.argv[1:4]

try:
    original = PdfReader(original_path)
    visual = PdfReader(visual_path)
except Exception as exc:
    raise SystemExit(f"could not read PDF while restoring links: {exc}")

if len(original.pages) != len(visual.pages):
    raise SystemExit(
        "cannot preserve links: original and fixed PDFs have different page counts"
    )

writer = PdfWriter()
for page in visual.pages:
    writer.add_page(page)


def pdf_number(value):
    if value is None or isinstance(value, NullObject):
        return NullObject()
    if isinstance(value, int):
        return NumberObject(value)
    return FloatObject(value)


def page_index_for_destination(destination):
    try:
        return original.get_destination_page_number(destination)
    except Exception:
        page = destination.get("/Page") if hasattr(destination, "get") else None
        if page is not None:
            try:
                return original.get_page_number(page.get_object())
            except Exception:
                pass
    return None


def destination_to_array(destination):
    page_index = page_index_for_destination(destination)
    if page_index is None or not 0 <= page_index < len(writer.pages):
        return None

    fit = str(destination.get("/Type", "/Fit"))
    out = ArrayObject([writer.pages[page_index].indirect_reference, NameObject(fit)])

    if fit == "/XYZ":
        out.extend(
            [
                pdf_number(destination.get("/Left")),
                pdf_number(destination.get("/Top")),
                pdf_number(destination.get("/Zoom")),
            ]
        )
    elif fit in ("/FitH", "/FitBH"):
        out.append(pdf_number(destination.get("/Top")))
    elif fit in ("/FitV", "/FitBV"):
        out.append(pdf_number(destination.get("/Left")))
    elif fit == "/FitR":
        out.extend(
            [
                pdf_number(destination.get("/Left")),
                pdf_number(destination.get("/Bottom")),
                pdf_number(destination.get("/Right")),
                pdf_number(destination.get("/Top")),
            ]
        )

    return out


def array_destination_to_array(destination):
    if not destination:
        return None

    target = destination[0]
    page_index = None
    try:
        page_index = original.get_page_number(target.get_object())
    except Exception:
        try:
            page_index = int(target)
        except Exception:
            pass

    if page_index is None or not 0 <= page_index < len(writer.pages):
        return None

    out = ArrayObject([writer.pages[page_index].indirect_reference])
    for item in destination[1:]:
        out.append(clone_simple(item))
    return out


def resolve_destination(value):
    value = value.get_object() if hasattr(value, "get_object") else value

    if isinstance(value, (str, TextStringObject)):
        destination = original.named_destinations.get(str(value))
        return destination_to_array(destination) if destination else None

    if isinstance(value, NameObject):
        name = str(value)
        destination = original.named_destinations.get(name[1:]) or original.named_destinations.get(name)
        return destination_to_array(destination) if destination else None

    if isinstance(value, ArrayObject):
        return array_destination_to_array(value)

    if isinstance(value, DictionaryObject):
        return destination_to_array(value)

    return None


def clone_simple(obj):
    obj = obj.get_object() if hasattr(obj, "get_object") else obj

    if isinstance(obj, DictionaryObject):
        out = DictionaryObject()
        for key, value in obj.items():
            out[NameObject(str(key))] = clone_simple(value)
        return out

    if isinstance(obj, ArrayObject):
        return ArrayObject([clone_simple(value) for value in obj])

    if isinstance(obj, NameObject):
        return NameObject(str(obj))

    if isinstance(obj, (TextStringObject, str)):
        return create_string_object(str(obj))

    if isinstance(obj, NullObject) or obj is None:
        return NullObject()

    if isinstance(obj, int):
        return NumberObject(obj)

    if isinstance(obj, float):
        return FloatObject(obj)

    try:
        return copy.copy(obj)
    except Exception:
        return obj


def clone_link_annotation(annotation_ref):
    annotation = annotation_ref.get_object()
    if annotation.get("/Subtype") != "/Link":
        return None

    out = DictionaryObject()
    for key in ("/Type", "/Subtype", "/Rect", "/Border", "/C", "/H", "/F", "/BS", "/Contents"):
        if key in annotation:
            out[NameObject(key)] = clone_simple(annotation[key])

    if "/A" in annotation:
        action = annotation["/A"].get_object()
        subtype = action.get("/S")

        if subtype == "/URI" and "/URI" in action:
            out[NameObject("/A")] = DictionaryObject(
                {
                    NameObject("/S"): NameObject("/URI"),
                    NameObject("/Type"): NameObject("/Action"),
                    NameObject("/URI"): clone_simple(action["/URI"]),
                }
            )
        elif subtype == "/GoTo" and "/D" in action:
            destination = resolve_destination(action["/D"])
            if destination is None:
                return None
            out[NameObject("/Dest")] = destination
        else:
            out[NameObject("/A")] = clone_simple(action)
    elif "/Dest" in annotation:
        destination = resolve_destination(annotation["/Dest"])
        if destination is None:
            return None
        out[NameObject("/Dest")] = destination
    else:
        return None

    return out


restored = 0
for page_index, (original_page, output_page) in enumerate(zip(original.pages, writer.pages)):
    if "/Annots" in output_page:
        del output_page["/Annots"]

    annotations = original_page.get("/Annots")
    if not annotations:
        continue

    output_page[NameObject("/Annots")] = ArrayObject()
    for annotation_ref in annotations:
        cloned = clone_link_annotation(annotation_ref)
        if cloned is None:
            continue
        cloned[NameObject("/P")] = output_page.indirect_reference
        output_page["/Annots"].append(writer._add_object(cloned))
        restored += 1

with open(output_path, "wb") as output_file:
    writer.write(output_file)

print(f"restored {restored} link annotations", file=sys.stderr)
PY
}

mode=flatten
out_file=
out_dir=
preserve_links=true
suffix=_preview
svg_scale=1
inputs=()

while (($#)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -o|--output)
      [[ $# -ge 2 ]] || die "--output requires a file"
      out_file=$2
      shift 2
      ;;
    --out-dir)
      [[ $# -ge 2 ]] || die "--out-dir requires a directory"
      out_dir=$2
      shift 2
      ;;
    --suffix)
      [[ $# -ge 2 ]] || die "--suffix requires text"
      suffix=$2
      shift 2
      ;;
    --mode)
      [[ $# -ge 2 ]] || die "--mode requires flatten or rewrite"
      mode=$2
      shift 2
      ;;
    --no-preserve-links)
      preserve_links=false
      shift
      ;;
    --svg-scale)
      [[ $# -ge 2 ]] || die "--svg-scale requires a positive number"
      svg_scale=$2
      shift 2
      ;;
    --)
      shift
      inputs+=("$@")
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      inputs+=("$1")
      shift
      ;;
  esac
done

[[ ${#inputs[@]} -gt 0 ]] || { usage >&2; exit 1; }
[[ -z "$out_file" || ${#inputs[@]} -eq 1 ]] || die "--output can only be used with one input"
[[ -z "$out_file" || -z "$out_dir" ]] || die "--output and --out-dir are mutually exclusive"
[[ "$mode" == "flatten" || "$mode" == "rewrite" ]] || die "--mode must be flatten or rewrite"

tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT

for input in "${inputs[@]}"; do
  [[ -f "$input" ]] || die "not a file: $input"

  ext=$(lower_ext "$input")
  output=${out_file:-$(default_output_for "$input")}
  mkdir -p "$(dirname "$output")"

  if [[ "$ext" == "pdf" ]]; then
    fix_pdf "$input" "$output"
  elif [[ "$ext" == "svg" ]]; then
    tmp_output="$tmp_dir/$(basename "$output").tmp.pdf"
    if [[ "$mode" == "flatten" ]]; then
      tmp_png="$tmp_dir/$(basename "${input%.*}").png"
      svg_to_raster_pdf "$input" "$tmp_output" "$tmp_png"
    else
      svg_to_vector_pdf "$input" "$tmp_output"
    fi
    mv "$tmp_output" "$output"
  else
    die "unsupported input type .$ext for $input"
  fi

  printf 'wrote %s\n' "$output"
done
